---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// One unified list: curated libs render at build time (instant paint,
// SEO), then the client script appends anything else the registry API
// knows about into the same table/grid. The curated/registry split is
// an implementation detail — users just see "the libraries".
const libs = (await getCollection("libs")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout title="Libraries — xeto.dev">
  <h1 class="text-3xl font-bold tracking-tight">Libraries</h1>
  <p class="mt-3 max-w-2xl text-ink-soft">
    Every library in the registry. Click through for details and spec-level
    browsing in the explorer.
  </p>

  <div class="mt-6 flex flex-wrap items-center justify-between gap-3">
    <div class="flex flex-wrap items-center gap-2">
      <input
        id="lib-filter"
        type="search"
        placeholder="Type to search, or click a category…"
        autocomplete="off"
        class="w-64 rounded-lg border border-line bg-paper px-3.5 py-2 text-sm placeholder:text-ink-soft focus:border-brand focus:outline-none sm:w-80"
      />
      <!-- quick-search pills seed the input -->
      <div class="flex flex-wrap gap-2" id="filter-pills">
        {
          ["ph", "sys", "elec", "doc"].map((p) => (
            <button
              type="button"
              data-pill={p}
              class="rounded-full border border-line bg-paper px-3 py-1 font-mono text-xs text-ink-soft hover:border-brand hover:text-brand"
            >
              {p}
            </button>
          ))
        }
      </div>
    </div>
    <!-- table/cards view toggle; choice persists in localStorage -->
    <div class="flex overflow-hidden rounded-lg border border-line bg-paper" role="group" aria-label="View">
      <button
        id="view-table"
        type="button"
        aria-label="Table view"
        class="flex h-9 w-9 items-center justify-center text-ink-soft hover:text-brand"
      >
        <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M2.5 4h11M2.5 8h11M2.5 12h11" />
        </svg>
      </button>
      <button
        id="view-cards"
        type="button"
        aria-label="Card view"
        class="flex h-9 w-9 items-center justify-center border-l border-line text-ink-soft hover:text-brand"
      >
        <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
          <rect x="2.5" y="2.5" width="4.5" height="4.5" rx="1" />
          <rect x="9" y="2.5" width="4.5" height="4.5" rx="1" />
          <rect x="2.5" y="9" width="4.5" height="4.5" rx="1" />
          <rect x="9" y="9" width="4.5" height="4.5" rx="1" />
        </svg>
      </button>
    </div>
  </div>

  <!-- table view -->
  <div id="table-view" class="table-wrap mt-4">
    <table class="data-table lib-table">
      <thead>
        <tr>
          <th>Library</th>
          <th>Version</th>
          <th>Summary</th>
          <th>Domain</th>
        </tr>
      </thead>
      <tbody id="table-rows">
        {
          libs.map((lib) => (
            <tr data-lib-row data-name={lib.data.name}>
              <td>
                <a href={`/libs/${lib.id}`} class="font-mono font-medium text-brand hover:underline">
                  {lib.data.name}
                </a>
              </td>
              <td class="font-mono text-ink-soft">{lib.data.version}</td>
              <td class="text-ink-soft">{lib.data.summary}</td>
              <td>
                {lib.data.domains.map((d) => (
                  <a href={`/domains/${d}`} class="text-xs text-brand hover:underline">
                    {d}
                  </a>
                ))}
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
    <p id="lib-empty" class="hidden px-4 py-6 text-sm text-ink-soft">
      No libraries match.
    </p>
  </div>

  <!-- card view (hidden until chosen) -->
  <div id="card-view" class="mt-4 hidden grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {
      libs.map((lib) => (
        <a
          href={`/libs/${lib.id}`}
          data-lib-row
          data-name={lib.data.name}
          class="card-brand block"
        >
          <div class="flex items-baseline justify-between gap-2">
            <h3 class="break-all font-mono font-semibold">{lib.data.name}</h3>
            <span class="card-soft font-mono text-xs">v{lib.data.version}</span>
          </div>
          <p class="card-soft mt-2 text-sm">{lib.data.summary}</p>
          {lib.data.domains.length > 0 && (
            <p class="card-accent mt-3 text-xs">{lib.data.domains.join(", ")}</p>
          )}
        </a>
      ))
    }
  </div>

  <script>
    import { searchLibs, esc } from "../../lib/registry";

    const el = (id: string) => document.getElementById(id)!;

    // ---- view toggle -----------------------------------------------------
    const views = { table: el("table-view"), cards: el("card-view") };
    const btns = { table: el("view-table"), cards: el("view-cards") };
    function setView(v: "table" | "cards") {
      views.table.classList.toggle("hidden", v !== "table");
      views.cards.classList.toggle("hidden", v !== "cards");
      btns.table.classList.toggle("bg-paper-soft", v === "table");
      btns.table.classList.toggle("text-brand", v === "table");
      btns.cards.classList.toggle("bg-paper-soft", v === "cards");
      btns.cards.classList.toggle("text-brand", v === "cards");
      localStorage.setItem("libs_view", v);
    }
    btns.table.addEventListener("click", () => setView("table"));
    btns.cards.addEventListener("click", () => setView("cards"));
    setView(localStorage.getItem("libs_view") === "table" ? "table" : "cards");

    // ---- merge in registry libs not covered by a curated static page ----
    const staticNames = new Set(
      [...document.querySelectorAll<HTMLElement>("[data-lib-row]")].map(
        (r) => r.dataset.name!,
      ),
    );

    function addRegistryLibs(libs: { name: string; version: string; doc: string }[]) {
      const fresh = libs.filter((l) => !staticNames.has(l.name));
      for (const l of fresh) {
        staticNames.add(l.name);
        const href = `/lib/${encodeURIComponent(l.name)}`;

        const tr = document.createElement("tr");
        tr.dataset.libRow = "";
        tr.dataset.name = l.name;
        tr.innerHTML = `
          <td><a href="${href}" class="font-mono font-medium text-brand hover:underline">${esc(l.name)}</a></td>
          <td class="font-mono text-ink-soft">${esc(l.version)}</td>
          <td class="text-ink-soft">${esc(l.doc)}</td>
          <td></td>`;
        el("table-rows").appendChild(tr);

        const card = document.createElement("a");
        card.href = href;
        card.dataset.libRow = "";
        card.dataset.name = l.name;
        card.className = "card-brand block";
        card.innerHTML = `
          <div class="flex items-baseline justify-between gap-2">
            <h3 class="break-all font-mono font-semibold">${esc(l.name)}</h3>
            <span class="card-soft font-mono text-xs">v${esc(l.version)}</span>
          </div>
          <p class="card-soft mt-2 text-sm">${esc(l.doc)}</p>`;
        el("card-view").appendChild(card);
      }
      if (fresh.length > 0) applyFilter();
    }

    searchLibs().then((res) => addRegistryLibs(res.libs)).catch(() => {});

    // ---- filter over the unified set (both views share data-lib-row) ----
    const input = el("lib-filter") as HTMLInputElement;
    function applyFilter() {
      const q = input.value.trim().toLowerCase();
      let shown = 0;
      for (const row of document.querySelectorAll<HTMLElement>("[data-lib-row]")) {
        const hit = row.textContent!.toLowerCase().includes(q);
        row.hidden = !hit;
        if (hit) shown++;
      }
      // both views hold the same set, so shown is doubled — any hit shows
      el("lib-empty").classList.toggle("hidden", shown > 0);
    }
    input.addEventListener("input", applyFilter);

    // pills seed the search box; clicking the active pill clears it
    document.querySelectorAll<HTMLButtonElement>("[data-pill]").forEach((b) =>
      b.addEventListener("click", () => {
        input.value = input.value === b.dataset.pill ? "" : b.dataset.pill!;
        applyFilter();
        input.focus();
      }),
    );
  </script>
</BaseLayout>
