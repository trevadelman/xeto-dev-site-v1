---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LibCard from "../../components/LibCard.astro";

const libs = (await getCollection("libs")).sort((a, b) =>
  a.data.name.localeCompare(b.data.name),
);
---

<BaseLayout title="Libraries — xeto.dev">
  <h1 class="text-3xl font-bold tracking-tight">Libraries</h1>
  <p class="mt-3 max-w-2xl text-ink-soft">
    Every library in the registry. Click through for details and spec-level
    browsing in the explorer.
  </p>
  <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {libs.map((lib) => <LibCard lib={lib} />)}
  </div>
</BaseLayout>
