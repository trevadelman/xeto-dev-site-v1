---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const libs = await getCollection("libs");
  return libs.map((lib) => ({ params: { id: lib.id }, props: { lib } }));
}

const { lib } = Astro.props;
const { name, version, summary, description, domains, depends, github } = lib.data;
const explorerHash = `#${name}*`;

// depends that are themselves in the registry get linked
const allIds = new Set((await getCollection("libs")).map((l) => l.id));
---

<BaseLayout title={`${name} — xeto.dev`} description={summary}>
  <nav class="text-sm text-ink-soft">
    <a href="/libs" class="hover:text-brand">Libraries</a>
    <span class="mx-1.5">/</span>
    <span class="font-mono text-ink">{name}</span>
  </nav>

  <div class="mt-6 grid gap-8 lg:grid-cols-[1fr_16rem]">
    <div>
      <div class="flex flex-wrap items-baseline gap-3">
        <h1 class="font-mono text-3xl font-bold tracking-tight">{name}</h1>
        <span class="font-mono text-sm text-ink-soft">v{version}</span>
      </div>
      <p class="mt-4 max-w-2xl text-lg text-ink-soft">{summary}</p>
      {description && <p class="mt-2 max-w-2xl text-ink-soft">{description}</p>}

      <div class="mt-6 rounded-lg border border-line bg-paper-soft p-4">
        <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">Install</p>
        <pre class="mt-2 overflow-x-auto text-sm"><code>xeto install {name}</code></pre>
        <p class="mt-2 text-xs text-ink-soft">CLI install is coming with the registry backend.</p>
      </div>
    </div>

    <!-- metadata sidebar -->
    <aside class="space-y-5 text-sm lg:border-l lg:border-line lg:pl-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">Version</p>
        <p class="mt-1 font-mono">{version}</p>
      </div>
      {
        domains.length > 0 && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">Domains</p>
            <div class="mt-1.5 flex flex-wrap gap-1.5">
              {domains.map((d) => (
                <a
                  href={`/domains/${d}`}
                  class="rounded-full bg-brand-faint px-2.5 py-0.5 text-xs text-brand hover:bg-brand hover:text-white"
                >
                  {d}
                </a>
              ))}
            </div>
          </div>
        )
      }
      {
        depends.length > 0 && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">Depends on</p>
            <ul class="mt-1.5 space-y-1 font-mono">
              {depends.map((d) =>
                allIds.has(d) ? (
                  <li>
                    <a href={`/libs/${d}`} class="text-brand hover:underline">
                      {d}
                    </a>
                  </li>
                ) : (
                  <li class="text-ink-soft">{d}</li>
                )
              )}
            </ul>
          </div>
        )
      }
      {
        github && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-ink-soft">Source</p>
            <a href={github} class="mt-1 inline-block text-brand hover:underline">
              GitHub ↗
            </a>
          </div>
        )
      }
    </aside>
  </div>

  <!-- embedded explorer scoped to this lib's virtual bundle -->
  <section class="mt-12">
    <div class="flex flex-wrap items-baseline justify-between gap-3">
      <div>
        <h2 class="text-xl font-semibold">Browse the specs</h2>
        <p class="mt-1 text-sm text-ink-soft">
          Every spec in <span class="font-mono">{name}</span>, live — click any
          type to inspect its slots, inheritance, and documentation.
        </p>
      </div>
      <a
        href={`/explorer/${explorerHash}`}
        class="text-sm font-medium text-brand hover:underline"
      >
        Open full explorer ↗
      </a>
    </div>
    <div class="mt-4 overflow-hidden rounded-lg border border-line shadow-sm">
      <iframe
        src={`/explorer/index.html?embed${explorerHash}`}
        title={`Xeto explorer — ${name}`}
        class="h-[70vh] w-full"
        loading="lazy"></iframe>
    </div>
  </section>
</BaseLayout>
