---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const libs = await getCollection("libs");
  return libs.map((lib) => ({ params: { id: lib.id }, props: { lib } }));
}

const { lib } = Astro.props;
const { name, version, summary, description, domains, github } = lib.data;
---

<BaseLayout title={`${name} — xeto.dev`} description={summary}>
  <nav class="text-sm text-ink-soft">
    <a href="/libs" class="hover:text-brand">Libraries</a>
    <span class="mx-1.5">/</span>
    <span class="font-mono text-ink">{name}</span>
  </nav>

  <div class="mt-6 flex flex-wrap items-baseline gap-3">
    <h1 class="font-mono text-3xl font-bold tracking-tight">{name}</h1>
    <span class="text-ink-soft">v{version}</span>
  </div>

  <p class="mt-4 max-w-3xl text-lg text-ink-soft">{summary}</p>
  {description && <p class="mt-3 max-w-3xl text-ink-soft">{description}</p>}

  <div class="mt-6 flex flex-wrap gap-2">
    {
      domains.map((d) => (
        <a
          href={`/domains/${d}`}
          class="rounded-full bg-brand-faint px-3 py-1 text-sm text-brand hover:bg-brand hover:text-white"
        >
          {d}
        </a>
      ))
    }
  </div>

  <div class="mt-8 flex flex-wrap gap-4">
    <a
      href={`/explorer/#xeto/lib/${name}`}
      class="rounded-lg bg-brand px-5 py-2.5 font-medium text-white hover:bg-brand-soft"
    >
      Explore specs
    </a>
    {
      github && (
        <a
          href={github}
          class="rounded-lg border border-line px-5 py-2.5 font-medium hover:border-brand hover:text-brand"
        >
          Source on GitHub
        </a>
      )
    }
  </div>

  <section class="mt-12 rounded-lg border border-line bg-paper-soft p-6">
    <h2 class="font-semibold">Install</h2>
    <p class="mt-2 text-sm text-ink-soft">
      CLI install is coming with the registry backend:
    </p>
    <pre
      class="mt-3 overflow-x-auto rounded bg-paper p-3 text-sm"><code>xeto install {name}</code></pre>
  </section>
</BaseLayout>
