---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFileSync } from "node:fs";

const libs = await getCollection("libs");
const featured = libs.filter((l) => l.data.featured);

// live stats from the explorer bundle manifest (build-time)
let libCount = 0;
let packKb = 0;
try {
  const manifest = JSON.parse(
    readFileSync(new URL("../../public/explorer/bundles/xeto/manifest.json", import.meta.url), "utf-8")
  );
  libCount = manifest.libs?.length ?? 0;
  packKb = Math.round((manifest.size ?? 0) / 1024);
} catch {
  /* manifest optional in early dev */
}

// hero sample: domain-neutral spec built from sys types — Xeto models any
// domain; the type links resolve against the live sys lib in the explorer
---

<BaseLayout title="xeto.dev — the registry for Xeto libraries">
  <section class="grid items-center gap-10 py-10 sm:py-16 lg:grid-cols-2">
    <div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        The Xeto library registry
      </h1>
      <p class="mt-5 max-w-xl text-lg text-ink-soft">
        Browse and explore typed data specifications — every spec, slot, and
        doc string, live in your browser. Publishing and CLI install are on
        the way.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/libs"
          class="rounded-lg bg-brand px-5 py-2.5 font-medium text-white hover:bg-brand-soft"
        >
          Browse libraries
        </a>
        <a
          href="/explorer/"
          class="rounded-lg border border-line px-5 py-2.5 font-medium text-ink hover:border-brand hover:text-brand"
        >
          Open the explorer
        </a>
      </div>
      {
        libCount > 0 && (
          <p class="mt-8 font-mono text-sm text-ink-soft">
            {libCount} libs &middot; one {packKb}KB pack &middot; zero backend
          </p>
        )
      }
    </div>

    <!-- real xeto source as the hero artifact; type names deep-link into the explorer -->
    <div class="overflow-hidden rounded-xl border border-line bg-paper-soft shadow-md">
      <div class="flex items-center gap-1.5 border-b border-line px-4 py-2.5">
        <span class="size-2.5 rounded-full bg-line"></span>
        <span class="size-2.5 rounded-full bg-line"></span>
        <span class="size-2.5 rounded-full bg-line"></span>
        <span class="ml-3 font-mono text-xs text-ink-soft">acme.orders :: Order</span>
      </div>
      <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed sm:text-sm"><code><span class="text-ink-soft">// A customer order — typed data models for any domain</span>
<span class="font-semibold text-brand">Order</span> : <a href="/explorer/#sys*/spec/sys::Dict" class="text-brand hover:underline">Dict</a> &#123;
  id:        <a href="/explorer/#sys*/spec/sys::Ref" class="text-brand hover:underline">Ref</a>
  customer:  <a href="/explorer/#sys*/spec/sys::Ref" class="text-brand hover:underline">Ref</a>&lt;of: Customer&gt;
  placed:    <a href="/explorer/#sys*/spec/sys::Date" class="text-brand hover:underline">Date</a>
  status:    Status <span class="text-ink-soft">// enum: pending | shipped | delivered</span>
  items:     <a href="/explorer/#sys*/spec/sys::List" class="text-brand hover:underline">List</a>&lt;of: LineItem&gt;
  total:     <a href="/explorer/#sys*/spec/sys::Number" class="text-brand hover:underline">Number</a>&lt;unit: "USD"&gt;
  notes:     <a href="/explorer/#sys*/spec/sys::Str" class="text-brand hover:underline">Str</a>?
&#125;</code></pre>
    </div>
  </section>

  <!-- how it works: one terminal transcript instead of a benefits grid -->
  <section class="py-6">
    <div class="overflow-hidden rounded-xl border border-line bg-ink text-paper dark:bg-paper-soft dark:text-ink">
      <pre class="overflow-x-auto p-5 font-mono text-xs leading-relaxed sm:text-sm"><code><span class="opacity-50">$</span> xeto install ph.points
<span class="opacity-50">&gt;</span> resolved ph.points 5.1.1 (+3 depends)
<span class="opacity-50">&gt;</span> namespace ready — 312 specs</code></pre>
    </div>
  </section>

  <section class="py-12">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xl font-semibold">Featured libraries</h2>
      <a href="/libs" class="text-sm text-brand hover:underline">All libraries →</a>
    </div>
    <div class="mt-5 overflow-hidden rounded-lg border border-line">
      <table class="lib-table w-full text-sm">
        <thead>
          <tr class="border-b border-line bg-paper-soft text-left text-xs uppercase tracking-wide text-ink-soft">
            <th class="px-4 py-2.5 font-semibold">Library</th>
            <th class="px-4 py-2.5 font-semibold">Version</th>
            <th class="px-4 py-2.5 font-semibold">Summary</th>
            <th class="px-4 py-2.5 font-semibold">Domain</th>
          </tr>
        </thead>
        <tbody>
          {
            featured.map((lib) => (
              <tr class="border-b border-line last:border-b-0 hover:bg-paper-soft">
                <td class="px-4 py-3">
                  <a href={`/libs/${lib.id}`} class="font-mono font-medium text-brand hover:underline">
                    {lib.data.name}
                  </a>
                </td>
                <td class="px-4 py-3 font-mono text-ink-soft">{lib.data.version}</td>
                <td class="px-4 py-3 text-ink-soft">{lib.data.summary}</td>
                <td class="px-4 py-3">
                  {lib.data.domains.map((d) => (
                    <a href={`/domains/${d}`} class="text-xs text-brand hover:underline">
                      {d}
                    </a>
                  ))}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</BaseLayout>
