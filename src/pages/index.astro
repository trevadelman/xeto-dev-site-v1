---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFileSync } from "node:fs";

const libs = await getCollection("libs");
const featured = libs.filter((l) => l.data.featured);

// live stats from the explorer bundle manifest (build-time)
let libCount = 0;
let packKb = 0;
try {
  const manifest = JSON.parse(
    readFileSync(new URL("../../public/explorer-app/bundles/xeto/manifest.json", import.meta.url), "utf-8")
  );
  libCount = manifest.libs?.length ?? 0;
  packKb = Math.round((manifest.size ?? 0) / 1024);
} catch {
  /* manifest optional in early dev */
}

// hero sample: domain-neutral spec built from sys types — Xeto models any
// domain; the type links resolve against the live sys lib in the explorer
---

<BaseLayout title="xeto.dev — the registry for Xeto libraries">
  <!-- npm-style search bar: sits on the hero's lavender band so the search
       runs seamlessly into the hero; the white pill pops against it.
       Sticks below the sticky header (top matches header height) so the
       lavender band scrolls with the chrome — no floating-bar look. -->
  <!-- full-bleed via negative margin (the left-1/2/translate trick fights
       position:sticky, which needs left untouched) -->
  <section class="sticky top-[4.25rem] z-10 -mt-10 ml-[calc(50%-50vw)] w-screen bg-page">
    <div class="mx-auto max-w-6xl px-6 py-4">
      <button
        data-search-open
        type="button"
        class="group flex w-full items-stretch overflow-hidden rounded-lg bg-paper text-left text-base text-ink-soft shadow-sm transition focus:outline-none focus:ring-2 focus:ring-brand"
      >
        <span class="flex min-w-0 flex-1 items-center gap-3 px-4 py-3 sm:px-5 sm:py-3.5">
          <!-- keyboard hint only makes sense (and only fits) on larger screens -->
          <span class="flex-1 truncate sm:hidden">Search libraries</span>
          <span class="hidden flex-1 sm:inline">Click here or press <kbd class="rounded border border-line bg-paper-soft px-1.5 py-0.5 font-mono text-sm">/</kbd> to search libraries</span>
        </span>
        <span class="flex items-center bg-nav px-5 text-nav-ink transition group-hover:bg-nav-soft sm:px-6" aria-label="Search">
          <svg class="h-5 w-5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <circle cx="7" cy="7" r="4.5" />
            <path d="m10.5 10.5 3 3" />
          </svg>
        </span>
      </button>
    </div>
  </section>

  <section class="grid items-center gap-10 py-12 sm:py-16 lg:grid-cols-2">
    <div>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        The Xeto library registry
      </h1>
      <p class="mt-5 max-w-xl text-lg text-ink-soft">
        Find, browse, and install Xeto libraries. Every spec is documented
        and searchable right here - no install needed to explore.
      </p>
      {
        libCount > 0 && (
          <p class="mt-8 font-mono text-sm text-ink-soft">
            {libCount} libs &middot; one {packKb}KB pack &middot; zero backend
          </p>
        )
      }
    </div>

    <!-- hero window: real xeto source plus the publish/install story as
         auto-advancing tabs — model -> publish -> install, right where the
         eye already is. Interaction stops the auto-cycle. -->
    <div>
    <div id="hero-window" class="overflow-hidden rounded-xl border border-line bg-paper shadow-md">
      <div class="flex items-center gap-1.5 bg-nav px-4 pt-2 pb-0">
        <span class="mb-2 size-2.5 rounded-full bg-nav-line"></span>
        <span class="mb-2 size-2.5 rounded-full bg-nav-line"></span>
        <span class="mb-2 size-2.5 rounded-full bg-nav-line"></span>
        <div class="ml-3 flex font-mono" role="tablist" aria-label="From spec to installed">
          <button class="hero-tab" role="tab" aria-selected="true" data-panel="panel-model">order.xeto<span class="tab-progress"></span></button>
          <button class="hero-tab" role="tab" aria-selected="false" data-panel="panel-publish">publish<span class="tab-progress"></span></button>
          <button class="hero-tab" role="tab" aria-selected="false" data-panel="panel-install">install<span class="tab-progress"></span></button>
        </div>
      </div>
      <!-- panels stack in one grid cell: the window keeps the tallest
           panel's size (locked from JS before typing empties a panel) and
           tabs cross-fade instead of reflowing -->
      <div id="hero-panels" class="grid min-h-[15rem]">
      <pre id="panel-model" role="tabpanel" class="hero-panel col-start-1 row-start-1 overflow-x-auto p-5 font-mono text-xs leading-relaxed sm:text-sm"><code><span class="text-ink-soft">// A customer order — typed data for any domain</span>
<span class="font-semibold text-brand">Order</span> : <span class="text-brand">Dict</span> &#123;
  customer:  <span class="text-brand">Ref</span>&lt;of: Customer&gt;
  placed:    <span class="text-brand">Date</span>
  items:     <span class="text-brand">List</span>&lt;of: LineItem&gt;
  total:     <span class="text-brand">Number</span>&lt;unit: "USD"&gt;
&#125;</code></pre>
      <pre id="panel-publish" role="tabpanel" class="hero-panel is-hidden col-start-1 row-start-1 overflow-x-auto p-5 font-mono text-xs leading-relaxed sm:text-sm"><code><span class="text-ink-soft">$</span> xeto publish acme.orders
<span class="text-ink-soft">
compiling acme.orders v1.0.2 ... ok
checking deps: sys 5.0.x ... ok</span>
<span class="text-brand">published acme.orders v1.0.2 → xeto.dev/libs/acme.orders</span></code></pre>
      <pre id="panel-install" role="tabpanel" class="hero-panel is-hidden col-start-1 row-start-1 overflow-x-auto p-5 font-mono text-xs leading-relaxed sm:text-sm"><code><span class="text-ink-soft">$</span> xeto install acme.orders
<span class="text-ink-soft">
resolving acme.orders ... v1.0.2
fetching acme.orders, sys ... ok</span>
<span class="text-brand">installed 2 libs — same types in every tool</span></code></pre>
      </div>
    </div>
    <p class="mt-3 text-center text-sm font-semibold text-ink-soft">
      model &rarr; publish &rarr; install
    </p>
    </div>
  </section>

  <script>
    // hero window: each tab types its content live (spec file and terminal
    // transcripts), then auto-advances. Click stops the auto-cycle for good;
    // hover pauses advancing; offscreen pauses; reduced-motion users get
    // instant full content and no cycling. Full content stays in the DOM
    // for no-JS/SEO — typing works by revealing existing text nodes.
    const win = document.getElementById("hero-window")!;
    const tabs = Array.from(win.querySelectorAll<HTMLButtonElement>(".hero-tab"));
    const CHAR_MS = 18;      // per-character typing speed
    const LINE_MS = 700;     // stagger between terminal output lines
    const CMD_MS = 600;      // beat after the command, like the CLI working
    const READ_MS = 2800;    // dwell after typing completes
    let current = 0;
    let timer: number | undefined;
    let run = 0;             // generation counter cancels stale animations
    let stopped = matchMedia("(prefers-reduced-motion: reduce)").matches;
    let done = stopped;      // after one full cycle, typing never replays
    let visible = false;

    // snapshot each panel's text nodes with their full content
    type Node = { node: Text; full: string };
    const panels = tabs.map((t) => {
      const el = document.getElementById(t.dataset.panel!)!;
      const walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT);
      const nodes: Node[] = [];
      let n: globalThis.Node | null;
      while ((n = walker.nextNode())) nodes.push({ node: n as Text, full: n.textContent ?? "" });
      return { el, nodes };
    });

    // lock the window height to the tallest panel before typing ever empties
    // one — typing then plays inside a fixed frame with room to breathe
    const panelsBox = document.getElementById("hero-panels")!;
    panelsBox.style.minHeight = `${Math.max(...panels.map((p) => p.el.scrollHeight))}px`;

    const sleep = (ms: number, gen: number) =>
      new Promise<boolean>((res) => setTimeout(() => res(gen === run), ms));

    async function typePanel(i: number, gen: number) {
      const { nodes } = panels[i]!;
      const cursor = document.createElement("span");
      cursor.className = "tw-cursor";
      nodes.forEach((x) => (x.node.textContent = ""));
      for (const [k, x] of nodes.entries()) {
        // whitespace-only nodes (the newlines between spans) restore
        // instantly — otherwise the next colored line glues onto the
        // previous one until restore() runs
        if (!x.full.trim()) { x.node.textContent = x.full; continue; }
        // terminal panels: nodes 0-1 are the "$ command" (typed per-char);
        // the rest is output, which streams line-by-line like a real CLI
        const byLine = i > 0 && k > 1;
        x.node.parentElement?.insertBefore(cursor, x.node.nextSibling);
        // pause after the command is typed, before output starts streaming
        if (i > 0 && k === 2 && !(await sleep(CMD_MS, gen))) return;
        if (byLine) {
          // slice-join keeps leading/blank lines intact while streaming,
          // so the gap after the command is there from the first line
          const lines = x.full.split("\n");
          for (let l = 1; l <= lines.length; l++) {
            x.node.textContent = lines.slice(0, l).join("\n");
            if (lines[l - 1]!.trim() && !(await sleep(LINE_MS, gen))) return;
          }
        } else {
          for (const ch of x.full) {
            x.node.textContent += ch;
            if (!(await sleep(CHAR_MS, gen))) return;
          }
        }
      }
      cursor.remove();
    }

    function restore(i: number) {
      panels[i]!.nodes.forEach((x) => (x.node.textContent = x.full));
      panels[i]!.el.querySelector(".tw-cursor")?.remove();
    }

    function select(i: number) {
      current = i;
      tabs.forEach((t, j) => {
        t.setAttribute("aria-selected", String(j === i));
        panels[j]!.el.classList.toggle("is-hidden", j !== i);
        t.querySelector(".tab-progress")!.classList.remove("run");
      });
    }

    async function play(i: number, andAdvance: boolean) {
      const gen = ++run;
      clearTimeout(timer);
      select(i);
      const reduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (reduced) { restore(i); return; }
      await typePanel(i, gen);
      if (gen !== run) return;
      restore(i);
      if (andAdvance && !stopped && visible) {
        // progress underline fills over the dwell so the switch is telegraphed
        const p = tabs[i]!.querySelector<HTMLElement>(".tab-progress")!;
        p.style.setProperty("--tab-interval", `${READ_MS}ms`);
        p.classList.add("run");
        // one cycle only: after install, settle permanently on the
        // completed order.xeto — no re-typing, no more advancing
        timer = window.setTimeout(() => {
          if (i === tabs.length - 1) { stopped = true; done = true; select(0); restore(0); }
          else play(i + 1, true);
        }, READ_MS);
      }
    }

    tabs.forEach((t, i) =>
      t.addEventListener("click", () => {
        stopped = true;
        // once the cycle has played, clicks just switch to populated text
        if (done) { run++; clearTimeout(timer); select(i); restore(i); }
        else play(i, false);
      }),
    );
    win.addEventListener("pointerenter", () => clearTimeout(timer));
    win.addEventListener("pointerleave", () => { if (!stopped && visible) play(current, true); });
    new IntersectionObserver((entries) => {
      const was = visible;
      visible = entries.some((e) => e.isIntersecting);
      if (visible && !was && !stopped) play(current, true);
      if (!visible) { run++; clearTimeout(timer); restore(current); if (stopped) done = true; }
    }).observe(win);
  </script>

  <!-- featured band: full-bleed paper surface — the color break after the
       lavender hero is what makes the page feel structured and short -->
  <section class="band-paper relative left-1/2 -mb-10 w-screen -translate-x-1/2 border-t border-line bg-paper">
    <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="flex items-baseline justify-between">
      <h2 class="text-xl font-semibold">Featured libraries</h2>
      <a href="/libs" class="text-sm text-brand hover:underline">All libraries →</a>
    </div>
    <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        featured.map((lib) => (
          <a
            href={`/libs/${lib.id}`}
            class="card-brand block"
          >
            <div class="flex items-baseline justify-between gap-2">
              <h3 class="break-all font-mono font-semibold">{lib.data.name}</h3>
              <span class="card-soft font-mono text-xs">v{lib.data.version}</span>
            </div>
            <p class="card-soft mt-2 text-sm">{lib.data.summary}</p>
            {lib.data.domains.length > 0 && (
              <p class="mt-3 flex flex-wrap gap-1.5">
                {lib.data.domains.map((d) => (
                  <span class="card-pill">{d}</span>
                ))}
              </p>
            )}
          </a>
        ))
      }
    </div>
    </div>
  </section>

</BaseLayout>
