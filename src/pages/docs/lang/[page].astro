---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { docPages, docNav, renderDoc } from "../../../lib/bundleDocs";

// Language reference pages rendered from the doc.xeto lib's markdown files —
// the same canonical source the explorer serves, shipped in the bundle output.
export async function getStaticPaths() {
  return docPages("doc.xeto").map((page) => ({ params: { page } }));
}

const { page } = Astro.params;
const { html, title } = renderDoc("doc.xeto", page, "/docs/lang/");
const nav = docNav("doc.xeto");
---

<BaseLayout title={`${title} — Xeto docs`}>
  <div class="grid gap-10 lg:grid-cols-[13rem_1fr]">
    <!-- reference sidebar from doc.xeto's own index.md ordering -->
    <aside class="hidden lg:block">
      <nav class="sticky top-20 max-h-[calc(100dvh-6rem)] overflow-y-auto pr-2 text-sm">
        <a href="/docs/lang" class="font-semibold text-ink hover:text-brand">
          Language reference
        </a>
        <ul class="mt-3 space-y-1.5 border-l border-line pl-3">
          {
            nav.map((item) => (
              <li>
                <a
                  href={`/docs/lang/${item.page}`}
                  class:list={[
                    "hover:text-brand",
                    item.page === page ? "font-medium text-brand" : "text-ink-soft",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </aside>

    <div class="min-w-0">
      <nav class="text-sm text-ink-soft">
        <a href="/docs/lang" class="hover:text-brand">Docs</a>
        <span class="mx-1.5">/</span>
        <span class="text-ink">{title}</span>
      </nav>
      <!-- mobile-only section nav; sidebar is hidden below lg -->
      <details class="mt-4 rounded-lg border border-line lg:hidden">
        <summary class="cursor-pointer px-4 py-2.5 text-sm font-medium">
          Language reference pages
        </summary>
        <ul class="space-y-1.5 border-t border-line px-4 py-3 text-sm">
          {
            nav.map((item) => (
              <li>
                <a
                  href={`/docs/lang/${item.page}`}
                  class:list={[
                    "hover:text-brand",
                    item.page === page ? "font-medium text-brand" : "text-ink-soft",
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>

      <article class="prose-docs mt-8 max-w-3xl" set:html={html} />
    </div>
  </div>
</BaseLayout>
