---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LibCard from "../../components/LibCard.astro";

export async function getStaticPaths() {
  const domains = await getCollection("domains");
  return domains.map((domain) => ({
    params: { slug: domain.data.slug },
    props: { domain },
  }));
}

const { domain } = Astro.props;
const libs = (await getCollection("libs")).filter((l) =>
  l.data.domains.includes(domain.data.slug),
);
---

<BaseLayout title={`${domain.data.name} — xeto.dev`} description={domain.data.blurb}>
  <nav class="text-sm text-ink-soft">
    <a href="/domains" class="hover:text-brand">Domains</a>
    <span class="mx-1.5">/</span>
    <span class="text-ink">{domain.data.name}</span>
  </nav>

  <h1 class="mt-6 text-3xl font-bold tracking-tight">{domain.data.name}</h1>
  <p class="mt-3 max-w-2xl text-ink-soft">{domain.data.blurb}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {libs.map((lib) => <LibCard lib={lib} />)}
  </div>
</BaseLayout>
