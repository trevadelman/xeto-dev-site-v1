---
import "../styles/global.css";
import { getCollection } from "astro:content";

// lib names with curated static pages — search results link there first,
// falling back to the live-registry /lib/{name} page for anything newer
const staticLibNames = (await getCollection("libs")).map((l) => l.data.name);

interface Props {
  title: string;
  description?: string;
}

const { title, description = "xeto.dev — the registry for Xeto typed-data libraries" } =
  Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// nav groups render as hover/click dropdowns; plain items as direct links
const nav = [
  {
    label: "Browse",
    items: [
      { href: "/libs", label: "Libraries" },
      { href: "/domains", label: "Domains" },
      { href: "/orgs", label: "Organizations" },
    ],
  },
  {
    label: "Learn",
    items: [
      { href: "/learn", label: "Xeto 101" },
      { href: "/docs/lang", label: "Docs" },
    ],
  },
  { href: "/explorer/", label: "Explorer" },
];

// active section for nav highlighting, e.g. /libs/ph -> /libs
const path = Astro.url.pathname;
const isActive = (href: string) =>
  path === href || path.startsWith(href.replace(/\/$/, "") + "/") || path === href.replace(/\/$/, "");
const isGroupActive = (items: { href: string }[]) => items.some((i) => isActive(i.href));

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL.href} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/xeto-logo.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <!-- social link previews (Slack, Twitter, LinkedIn, ...) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={new URL("/xeto-logo.png", Astro.site).href} />
    <meta name="twitter:card" content="summary" />
    <script is:inline>
      // set theme before paint to avoid flash; persisted in localStorage
      // light by default; user's explicit choice persists in localStorage
      document.documentElement.dataset.theme = localStorage.getItem("theme") ?? "light";
    </script>
  </head>
  <body class="flex min-h-dvh flex-col font-sans antialiased">
    <header class="sticky top-0 z-20 border-b border-line bg-paper/85 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <img src="/xeto-logo.png" alt="" class="h-7 w-7 rounded" />
          <span>xeto<span class="text-brand">.dev</span></span>
        </a>
        <div class="flex items-center gap-3">
          <nav class="hidden items-center gap-5 text-sm sm:flex">
            {nav.map((item) =>
              item.items ? (
                <div class="group relative" data-dropdown>
                  <span
                    data-dropdown-trigger
                    class:list={[
                      "flex cursor-default select-none items-center gap-1.5 py-1 hover:text-brand",
                      isGroupActive(item.items) ? "font-medium text-brand" : "text-ink-soft",
                    ]}
                  >
                    {item.label}
                    <svg
                      class="h-3 w-3 opacity-60 transition-transform duration-150 group-hover:rotate-180"
                      viewBox="0 0 12 12"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M3 4.5 6 7.5 9 4.5" />
                    </svg>
                  </span>
                  {/* pt-2 bridges the hover gap between trigger and panel;
                      [.open]& handles touch devices where hover doesn't apply */}
                  <div class="invisible absolute left-0 pt-2 opacity-0 transition-all duration-150 group-hover:visible group-hover:opacity-100 group-[.open]:visible group-[.open]:opacity-100">

                    <div class="min-w-44 rounded-lg border border-line bg-paper py-2 shadow-lg shadow-black/5">
                      {item.items.map((sub) => (
                        <a
                          href={sub.href}
                          class:list={[
                            "mx-2 block whitespace-nowrap rounded px-3 py-2 hover:bg-paper-soft hover:text-brand",
                            isActive(sub.href) ? "font-medium text-brand" : "text-ink-soft",
                          ]}
                        >
                          {sub.label}
                        </a>
                      ))}
                    </div>
                  </div>

                </div>
              ) : (
                <a
                  href={item.href}
                  class:list={[
                    "hover:text-brand",
                    isActive(item.href!) ? "font-medium text-brand" : "text-ink-soft",
                  ]}
                >
                  {item.label}
                </a>
              ),
            )}
          </nav>
          <button
            id="search-toggle"
            type="button"
            aria-label="Search libraries"
            class="flex h-8 w-8 items-center justify-center rounded border border-line text-ink-soft transition hover:border-brand hover:text-brand"
          >
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <circle cx="7" cy="7" r="4.5" />
              <path d="m10.5 10.5 3 3" />
            </svg>
          </button>

          <a
            id="session-indicator"
            href="/account"
            class="invisible hidden h-8 items-center gap-1.5 whitespace-nowrap rounded border border-line px-2.5 text-sm text-ink-soft transition hover:border-brand hover:text-brand sm:flex"
          ></a>


          <button
            id="menu-toggle"
            type="button"
            aria-label="Open menu"
            aria-expanded="false"
            class="flex h-8 w-8 items-center justify-center rounded border border-line text-ink-soft transition hover:border-brand hover:text-brand sm:hidden"
          >
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <path d="M2.5 4.5h11M2.5 8h11M2.5 11.5h11" />
            </svg>
          </button>
        </div>
      </div>

      <!-- mobile nav panel: overlays content below the sticky header -->
      <nav
        id="mobile-nav"
        class="absolute inset-x-0 top-full hidden border-b border-t border-line bg-paper pb-3 shadow-lg shadow-black/5 sm:hidden"
      >

        {nav.map((item) =>
          item.items ? (
            <div>
              <p class="px-6 pb-1 pt-3 text-xs font-semibold uppercase tracking-wide text-ink-soft">
                {item.label}
              </p>
              {item.items.map((sub) => (
                <a
                  href={sub.href}
                  class:list={[
                    "block px-6 py-2 text-sm",
                    isActive(sub.href) ? "font-medium text-brand" : "text-ink-soft",
                  ]}
                >
                  {sub.label}
                </a>
              ))}
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                "block px-6 py-3 text-sm",
                isActive(item.href!) ? "font-medium text-brand" : "text-ink-soft",
              ]}
            >
              {item.label}
            </a>
          ),
        )}
        <a
          id="mobile-account-link"
          href="/account"
          class:list={[
            "block border-t border-line px-6 py-3 text-sm",
            isActive("/account") ? "font-medium text-brand" : "text-ink-soft",
          ]}
        >
          Account
        </a>
      </nav>

    </header>

    <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-10">
      <slot />
    </main>

    <footer class="mt-auto border-t border-line">
      <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-8 text-left text-sm text-ink-soft"
      >
        <p>&copy; {new Date().getFullYear()} XetoBase™. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="/about" class="hover:text-brand">About</a>
          <a href="/contact" class="hover:text-brand">Contact</a>
          <a href="/legal" class="hover:text-brand">Terms</a>
          <button
            id="theme-toggle"
            type="button"
            aria-label="Toggle theme"
            class="flex h-8 w-8 shrink-0 items-center justify-center rounded border border-line text-ink-soft transition hover:border-brand hover:text-brand"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <circle cx="8" cy="8" r="5.5" />
              <path d="M8 2.5v11" />
              <path d="M8 2.5a5.5 5.5 0 0 1 0 11" fill="currentColor" stroke="none" />
            </svg>
          </button>


        </div>
      </div>

    </footer>

    <!-- header search: minimal palette over the registry lib search API -->
    <div id="search-backdrop" class="fixed inset-0 z-30 hidden bg-black/20 backdrop-blur-sm">
      <div class="mx-auto mt-24 w-full max-w-lg px-6">
        <div class="overflow-hidden rounded-lg border border-line bg-paper shadow-lg shadow-black/10">
          <input
            id="search-input"
            type="text"
            placeholder="Search libraries…"
            autocomplete="off"
            class="w-full border-b border-line bg-transparent px-4 py-3 text-sm outline-none placeholder:text-ink-soft"
          />
          <div id="search-results" class="max-h-80 overflow-y-auto py-1.5"></div>
        </div>
      </div>
    </div>



    <script is:inline>
      // touch support for hover dropdowns: first tap opens, tap elsewhere closes.
      // pointerType check keeps mouse behavior hover-only (no click stickiness).
      document.querySelectorAll("[data-dropdown]").forEach((dd) => {
        dd.querySelector("[data-dropdown-trigger]").addEventListener("pointerup", (e) => {
          if (e.pointerType !== "touch") return;
          const wasOpen = dd.classList.contains("open");
          document.querySelectorAll("[data-dropdown].open").forEach((o) => o.classList.remove("open"));
          if (!wasOpen) dd.classList.add("open");
        });
      });
      document.addEventListener("pointerup", (e) => {
        if (!e.target.closest("[data-dropdown]"))
          document.querySelectorAll("[data-dropdown].open").forEach((o) => o.classList.remove("open"));
      });

      const menuBtn = document.getElementById("menu-toggle");

      menuBtn?.addEventListener("click", () => {
        const panel = document.getElementById("mobile-nav");
        const open = panel.classList.toggle("hidden");
        menuBtn.setAttribute("aria-expanded", String(!open));
      });
      const flipTheme = () => {
        const el = document.documentElement;
        const next = el.dataset.theme === "dark" ? "light" : "dark";
        el.dataset.theme = next;
        localStorage.setItem("theme", next);
      };
      document.getElementById("theme-toggle")?.addEventListener("click", flipTheme);


    </script>


    <script define:vars={{ staticLibNames }} is:inline>
      // exposed for the module script below (Astro define:vars only works
      // on inline scripts)
      window.__staticLibs = new Set(staticLibNames);
    </script>

    <script>
      import { searchLibs, esc } from "../lib/registry";
      import { session, me, cachedWho } from "../lib/session";

      const staticLibs: Set<string> = (window as any).__staticLibs ?? new Set();
      const libHref = (name: string) =>
        staticLibs.has(name) ? `/libs/${encodeURIComponent(name)}` : `/lib/${encodeURIComponent(name)}`;

      // header session indicator: signed out -> "Sign in", signed in ->
      // "@handle" (or display name if no handle claimed yet). Renders
      // synchronously from the last-known cached label (same paint as
      // the rest of the header, no flicker) then reconciles silently
      // once me() resolves — only visibly changes if it was stale/wrong.
      const indicator = document.getElementById("session-indicator")!;
      indicator.textContent = cachedWho() ?? "Sign in";
      indicator.classList.remove("invisible");

      if (session()) {
        me().then((account) => {
          indicator.textContent = account
            ? "@" + (account.handle ?? account.display_name)
            : "Sign in";
        });
      }


      const backdrop = document.getElementById("search-backdrop")!;

      const input = document.getElementById("search-input") as HTMLInputElement;
      const results = document.getElementById("search-results")!;
      let debounce: number;

      function openSearch() {
        backdrop.classList.remove("hidden");
        input.value = "";
        results.innerHTML = "";
        input.focus();
      }
      function closeSearch() {
        backdrop.classList.add("hidden");
      }

      document.getElementById("search-toggle")?.addEventListener("click", openSearch);
      backdrop.addEventListener("click", (e) => {
        if (e.target === backdrop) closeSearch();
      });
      window.addEventListener("keydown", (e) => {
        const tag = (document.activeElement as HTMLElement)?.tagName;
        if (e.key === "/" && tag !== "INPUT" && tag !== "TEXTAREA") { e.preventDefault(); openSearch(); }
        else if (e.key === "Escape") closeSearch();
      });

      // keyboard nav through results: down/up move the highlight,
      // enter follows the highlighted result (or the first one)
      let active = -1;
      function items(): HTMLAnchorElement[] {
        return Array.from(results.querySelectorAll("a"));
      }
      function highlight(i: number) {
        const list = items();
        if (list.length === 0) return;
        active = (i + list.length) % list.length;
        list.forEach((a, j) => a.classList.toggle("bg-paper-soft", j === active));
        list[active]?.scrollIntoView({ block: "nearest" });
      }
      input.addEventListener("keydown", (e) => {
        if (e.key === "ArrowDown") { e.preventDefault(); highlight(active + 1); }
        else if (e.key === "ArrowUp") { e.preventDefault(); highlight(active - 1); }
        else if (e.key === "Enter") {
          const target = items()[active] ?? items()[0];
          if (target) target.click();
        }
      });

      input.addEventListener("input", () => {
        clearTimeout(debounce);
        const q = input.value.trim();
        if (!q) { results.innerHTML = ""; return; }
        active = -1;
        debounce = window.setTimeout(async () => {
          const { libs } = await searchLibs(q, 8);
          results.innerHTML =
            libs.length === 0
              ? `<p class="px-4 py-3 text-sm text-ink-soft">No libraries match &ldquo;${q.replace(/</g, "&lt;")}&rdquo;</p>`
              : libs
                  .map(
                    (l) => `
            <a href="${libHref(l.name)}" class="mx-1.5 block rounded px-3 py-2 hover:bg-paper-soft">
              <span class="font-mono text-sm font-medium text-brand">${esc(l.name)}</span>
              <span class="ml-2 font-mono text-xs text-ink-soft">${esc(l.version)}</span>
              <p class="mt-0.5 truncate text-xs text-ink-soft">${esc(l.doc)}</p>
            </a>`,
                  )
                  .join("");
        }, 200);
      });
    </script>

  </body>
</html>
